NODE_ENV=development
PORT=4000
LOG_LEVEL=info

MONGODB_URI=mongodb://mongodb:27017/auth_service
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=http://localhost:3000

# Optional: Jest / CI — use a real MongoDB when mongodb-memory-server cannot run (sandbox, etc.)
# TEST_MONGODB_URI=mongodb://127.0.0.1:27017/auth_jest
# MONGOMS_SYSTEM_BINARY=/opt/homebrew/bin/mongod
